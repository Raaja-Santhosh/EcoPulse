# ==============================================================================
# EcoPulse Environment Variables
# ==============================================================================
# Copy this file to `.env` and fill in the values.

# ---------- Backend (FastAPI) ----------

# Google Gemini API Key — used by the /api/chat endpoint for AI responses.
# Optional: if not set, users can provide their own key via the X-Gemini-API-Key header.
GEMINI_API_KEY=

# Frontend origin URL — used for CORS. Set this to your deployed frontend URL.
# Example: https://eco-pulse-rouge.vercel.app
FRONTEND_URL=

# ---------- Frontend (Vite / React) ----------

# Backend API URL — the base URL for the FastAPI backend.
# Example: https://ecopulse-jmff.onrender.com
VITE_BACKEND_URL=http://localhost:8000
